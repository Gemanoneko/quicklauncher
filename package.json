{
  "name": "quicklauncher",
  "productName": "QuickLauncher",
  "version": "1.22.0",
  "description": "Cyberpunk-themed desktop quick launcher",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish always",
    "postbuild": "node scripts/cleanup-releases.js",
    "pack": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.antigravity.quicklauncher",
    "productName": "QuickLauncher",
    "copyright": "Copyright © 2025 Antigravity Projects",
    "icon": "icon.png",
    "directories": {
      "output": "dist",
      "buildResources": "."
    },
    "files": [
      "src/**/*",
      "icon.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "Gemanoneko",
      "repo": "quicklauncher",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.0"
  }
}
